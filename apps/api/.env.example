# Base de données PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:ton_mot_de_passe@localhost:5432/portfolio"

# Clé secrète pour signer les JWT (génère une clé aléatoire longue)
JWT_SECRET="change_moi_avec_une_cle_secrete_tres_longue_et_aleatoire"

# Port du serveur
PORT=3001

# Origine autorisée pour CORS (ton frontend)
CORS_ORIGIN="http://localhost:3000"

# Environnement
NODE_ENV="development"
